# 复制本文件为 .env，并填入实际值
# 服务端口
PORT=3000

# 运行环境：development / production
NODE_ENV=development

# Session 加密密钥（务必修改为随机长字符串，可用：openssl rand -hex 32）
SESSION_SECRET=please-change-me-to-a-long-random-string

# 允许跨域访问的前端域名（多个用逗号分隔）。开发时可留空，默认放行所有 localhost
# 示例：https://admin.your-domain.com,https://chat.your-domain.com
CORS_ORIGINS=
